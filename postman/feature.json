    {
      "name": "add comment",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const rnd = new RandomUtils();",
              "pm.collectionVariables.set(\"message\", rnd.getWord(30));",
              "let user = {",
              "    url: pm.collectionVariables.get(\"baseUrl\") + '/admin/users',",
              "    method: 'POST',",
              "    header: {",
              "        'Content-Type': 'application/json'",
              "    },",
              "    body: {",
              "        mode: 'raw',",
              "        raw: JSON.stringify(rnd.getUser())",
              "    }",
              "};",
              "let cat = {",
              "    url: pm.collectionVariables.get(\"baseUrl\") + '/admin/categories',",
              "    method: 'POST',",
              "    header: {",
              "        'Content-Type': 'application/json'",
              "    },",
              "    body: {",
              "        mode: 'raw',",
              "        raw: JSON.stringify(rnd.getCat())",
              "    }",
              "};",
              "",
              "pm.sendRequest(user, function (err, res){",
              "        let jsonData = res.json();",
              "        pm.collectionVariables.set('userId',jsonData.id);",
              "        pm.sendRequest(cat, function (err, res){",
              "            let jsonData = res.json();",
              "            pm.collectionVariables.set('catId',jsonData.id);",
              "            cat = jsonData.id;",
              "            let event = {",
              "                url: pm.collectionVariables.get(\"baseUrl\") + '/users/' + pm.collectionVariables.get(\"userId\") + '/events',",
              "                method: 'POST',",
              "                header: {",
              "                    'Content-Type': 'application/json'",
              "                },",
              "                body: {",
              "                    mode: 'raw',",
              "                    raw: JSON.stringify(rnd.getEvent(cat))",
              "                }",
              "            };",
              "            pm.sendRequest(event, function (err, res){",
              "                let jsonData = res.json();",
              "                pm.collectionVariables.set('eventId',jsonData.id);",
              "                let event2 = {",
              "                url: pm.collectionVariables.get(\"baseUrl\") + '/admin/events/' + pm.collectionVariables.get(\"eventId\"),",
              "                method: 'PATCH',",
              "                header: {",
              "                    'Content-Type': 'application/json'",
              "                },",
              "                body: {",
              "                    mode: 'raw',",
              "                    raw: JSON.stringify({stateAction : 'PUBLISH_EVENT'})",
              "                }",
              "                };",
              "                pm.sendRequest(event2,function(err,res){",
              "                        ",
              "                }); ",
              "            });",
              "        });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200,201]);",
              "});",
              "",
              "pm.test(\"Test user 'id' field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData.id, '\"id\" must be above 0 ').to.be.above(0);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
