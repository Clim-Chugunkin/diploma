    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "RandomUtils = class {",
          "    constructor() {}",
          "    getUser() {",
          "        return {",
          "            name: pm.variables.replaceIn('{{$randomFullName}}'),",
          "            email: pm.variables.replaceIn('{{$randomEmail}}'),",
          "        };",
          "    }",
          "",
          "    changeState(){",
          "        return {stateAction : \"PUBLISH_EVENT\"};",
          "    }",
          "",
          "    getCat(){",
          "        return {",
          "            name: this.getWord(10)    ",
          "        };",
          "    }",
          "",
          "    getComp(){",
          "        return {",
          "             events : [pm.collectionVariables.get(\"eventId\")],",
          "             pinned : true,",
          "             title : this.getWord(20)   ",
          "        };",
          "    }",
          "",
          "    getWord(length = 1) {",
          "        let result = '';",
          "        const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';",
          "        const charactersLength = characters.length;",
          "        let counter = 0;",
          "        while (counter < length) {",
          "            result += characters.charAt(Math.floor(Math.random() * charactersLength));",
          "            counter += 1;",
          "        }",
          "        return result;",
          "    }",
          "",
          "    getEvent(cat){",
          "        return {",
          "                annotation: this.getWord(34),",
          "                category: cat,",
          "                description: this.getWord(50),",
          "                eventDate: \"2026-12-31 15:10:05\",",
          "                location: {",
          "                        lat: 55.754167,",
          "                        lon: 37.62",
          "                        },",
          "                paid: true,",
          "                participantLimit: 10,",
          "                requestModeration: false,",
          "                title: this.getWord(12)",
          "        };",
          "    }",
          "}"
        ]
      }
