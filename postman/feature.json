              "                    body: {",
              "                        mode: 'raw',",
              "                        raw: JSON.stringify({message : rnd.getWord(27)})",
              "                    }",
              "                    };",
              "                    pm.sendRequest(comment,function(err,res){",
              "                        let jsonData = res.json();",
              "                        pm.collectionVariables.set('commentId',jsonData.id);",
              "                        pm.collectionVariables.set(\"message\", jsonData.comment);",
              "                    });",
              "                }); ",
              "            });",
              "        });",
              "});"
